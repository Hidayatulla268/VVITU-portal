# VVIT Portal Environment Settings Example
# Rename this file to '.env' and fill in your values.

# Django Security
DJANGO_SECRET_KEY=vvitu-dev-fallback-key-DO-NOT-USE-in-production-replace-me-immediately-2024
DJANGO_DEBUG=True
# Comma-separated allowed hosts:
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (for PostgreSQL in production)
# DATABASE_URL=postgres://user:password@host:port/dbname

# Redis URL (for Caching & Sessions in production)
# REDIS_URL=redis://127.0.0.1:6379/1

# Email SMTP Settings (optional, falls back to console email in dev)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password

# AI Chatbot API Key (optional)
# GEMINI_API_KEY=your_gemini_api_key_here
